@article{Siebert2001ozone,
 author = {Siebert, R\"udiger and Schinke, Reinhard and Bittererov\'a, Martina},
 title = {Spectroscopy of ozone at the dissociation threshold: {Quantum} calculations of bound and resonance states on a new global potential energy surface},
 journal = {Phys. Chem. Chem. Phys.},
 year = {2001},
 volume = {3},
 issue = {10},
 pages = {1795--1798},
 publisher = {Royal Society of Chemistry (RSC)},
 doi = {10.1039/b102830h},
 abstract = {The spectroscopy of O3(̃) near the O(3P) + O2(3\ensuremath{\Sigma}g\ensuremath{-}) threshold is investigated by means of quantum mechanical dynamics calculations (filter diagonalization with absorbing potential) on a global potential energy surface for the ground electronic state\{,\} ̃1A'(1A1)\{,\} obtained from multi-reference configuration interaction calculations. Most of the highly excited bound states and even a substantial number of the resonance states can be clearly assigned. As a result\{,\} the resonance widths show a pronounced state specificity with the longest lifetime being of the order of 1 ns{\textemdash}three orders of magnitude below the prediction of transition state theory.},
 number = {10},
 source = {Crossref},
 issn = {1463-9076, 1463-9084},
}

