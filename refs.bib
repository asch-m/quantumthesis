@article{Sagadevan2017hydrocarbons,
 author = {Sagadevan, Arunachalam and Hwang, Kuo Chu and Su, Ming-Der},
 title = {Singlet oxygen-mediated selective {C{\textendash}H} bond hydroperoxidation of ethereal hydrocarbons},
 journal = {Nat. Commun.},
 year = {2017},
 month = nov,
 day = {27},
 volume = {8},
 number = {1},
 pages = {1812},
 abstract = {Singlet O2 is a key reactive oxygen species responsible for photodynamic therapy and is generally recognized to be chemically reactive towards C=C double bonds. Herein, we report the hydroperoxidation/lactonization of \ensuremath{\alpha}-ethereal C{\textendash}H bonds by singlet O2 (1\ensuremath{\Delta}g) under exceptionally mild conditions, i.e., room temperature and ambient pressure, with modest to high yields (38{\textasciitilde}90\%) and excellent site selectivity. Singlet O2 has been known for \ensuremath{>}90 years, but was never reported to be able to react with weakly activated C{\textendash}H bonds in saturated hydrocarbons. Theoretical calculations indicate that singlet O2 directly inserts into the \ensuremath{\alpha}-ethereal C{\textendash}H bond in one step with conservation of steric configuration in products. The current discovery of chemical reaction of singlet oxygen with weakly activated solvent C{\textendash}H bonds, in addition to physical relaxation pathway, provides an important clue to a 35-year-old unresolved mystery regarding huge variations of solvent dependent lifetime of singlet O2.},
 issn = {2041-1723},
 doi = {10.1038/s41467-017-01906-5},
 source = {Crossref},
 publisher = {Springer Science and Business Media LLC},
}

