@inbook{Onishi2018Oxygen,
 author = {Onishi, Taku},
 title = {Molecular Orbital Calculation of Diatomic Molecule},
 booktitle = {Quantum Computational Chemistry},
 year = {2017},
 publisher = {Springer Singapore},
 address = {Singapore},
 pages = {113--157},
 abstract = {Covalent bonding is formed through orbital overlap between orbitals of different atoms. It is classified into \ensuremath{\sigma}-type and \ensuremath{\pi}-type by the difference of the interaction between lobes. In this chapter, chemical bonding formation of diatomic molecule is clearly explained from the viewpoints of molecular orbital analysis and energetics. In homonuclear diatomic molecule, chemical bonding formations of hydrogen molecule, lithium dimer, nitrogen molecule and oxygen molecule are explained through concrete calculation results. Triplet and singlet spin states are compared in oxygen molecule. The stability of triplet oxygen molecule is clearly explained. The high reactivity of superoxide is also discussed. On the other hand, in heteronuclear diatomic molecule, chemical bonding formations of hydrogen fluoride, hydrogen chloride, hydroxide and carbon oxide are explained through concrete calculation results. The difference of acidity is discussed in comparison with hydrogen fluoride and hydrogen chloride. In comparison with hydroxide, the reactivity of hydroxide radical is also discussed. Point charge notation has been used for atom and molecule. However, the limit of point charge denotation is pointed out.},
 isbn = {9789811059322, 9789811059339},
 doi = {10.1007/978-981-10-5933-9_8},
 source = {Crossref},
 chapter = {Molecular Orbital Calculation of Diatomic Molecule},
 month = sep,
}

@article{GRAFENSTEIN1998593,
 author = {Gr\"afenstein, J\"urgen and Kraka, Elfi and Cremer, Dieter},
 title = {Density functional theory for open-shell singlet biradicals},
 journal = {Chem. Phys. Lett.},
 volume = {288},
 number = {5-6},
 pages = {593--602},
 year = {1998},
 issn = {0009-2614},
 doi = {10.1016/s0009-2614(98)00335-2},
 abstract = {The description of open-shell singlet (OSS) \ensuremath{\sigma}{\textendash}\ensuremath{\pi} biradicals by density functional theory (DFT) requires at least a two-configurational (TC) or, in general, a MC-DFT approach, which bears many unsolved problems. These can be avoided by reformulating the TC description in the spirit of restricted open shell theory for singlets (ROSS) and developing an exchange-correlation functional for ROSS-DFT. ROSS-DFT turns out to lead to reliable descriptions of geometry and vibrational frequencies for OSS biradicals. The relative energies of the OSS states obtained at the ROSS-B3LYP/6-311G(d,p) level are often better than the corresponding ROSS-MP2 results. However, in those cases where spin polarization in a conjugated \ensuremath{\pi} systems plays a role, DFT predicts the triplet state related to the OSS state 2{\textendash}4 kcal/mol too stable.},
 source = {Crossref},
 publisher = {Elsevier BV},
 month = may,
}
