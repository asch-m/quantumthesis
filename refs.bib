@book{brandt_improved_1979,
	title = {Improved dissociation efficiency in {TE} pulsed copper halide lasers},
	url = {https://ui.adsabs.harvard.edu/abs/1979lase.conf..380B},
	abstract = {The results of experiments aimed at increasing the specific output energy of transversely-excited (TE) copper halide lasers by improving the homogeneity of the laser discharge and the dissociation efficiency are reported. Stabilization of high-voltage dissociation pulses through the application of a high-voltage, low-energy preconditioning pulse to the laser mixture has permitted increased specific input energies in both dissociation and excitation pulses while maintaining good discharge homogeneity. Specific laser output energies of 20 micro-J/cu cm have been achieved in a TE copper bromide laser of active volume 70 cu cm. The use of low-voltage (500 V), quasi-CW (10 microsec duration) dissociation pulses has resulted in dissociation efficiencies an order of magnitude greater than those achieved with high-voltage dissociation, and has also improved the stability of the laser discharge.},
	urldate = {2023-05-05},
	author = {Brandt, M. and Piper, J. A.},
